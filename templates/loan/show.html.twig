{% extends 'base.html.twig' %}

{% block title %}Emprunt #{{ loan.id }}{% endblock %}

{% block body %}
<div class="container">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('app_loan_index') }}">Emprunts</a></li>
            <li class="breadcrumb-item active">Emprunt #{{ loan.id }}</li>
        </ol>
    </nav>

    {% set overdue = loan.status == 'borrowed' and loan.dueDate < date() %}

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card mb-4 {{ overdue ? 'border-danger' : '' }}">
                <div class="card-header d-flex justify-content-between align-items-center {{ overdue ? 'bg-danger text-white' : '' }}">
                    <h5 class="mb-0">Emprunt #{{ loan.id }}</h5>
                    {% if loan.status == 'borrowed' %}
                        <span class="badge {{ overdue ? 'bg-light text-danger' : 'bg-warning text-dark' }} fs-6">
                            {{ overdue ? 'En retard' : 'En cours' }}
                        </span>
                    {% else %}
                        <span class="badge bg-success fs-6">Retourné</span>
                    {% endif %}
                </div>
                <div class="card-body">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <h6 class="text-muted mb-2">Livre</h6>
                            <div class="fw-semibold">
                                <a href="{{ path('app_book_show', {id: loan.book.id}) }}">{{ loan.book.title }}</a>
                            </div>
                            <div class="text-muted small">{{ loan.book.author }}</div>
                            <span class="badge bg-secondary mt-1">{{ loan.book.genre }}</span>
                        </div>

                        <div class="col-md-6">
                            <h6 class="text-muted mb-2">Adhérent</h6>
                            <div class="fw-semibold">
                                <a href="{{ path('app_member_show', {id: loan.member.id}) }}">{{ loan.member.fullName }}</a>
                            </div>
                            <div class="text-muted small">{{ loan.member.email }}</div>
                        </div>

                        <div class="col-md-4">
                            <h6 class="text-muted mb-1">Emprunté le</h6>
                            <div>{{ loan.borrowedAt|date('d/m/Y à H:i') }}</div>
                        </div>

                        <div class="col-md-4">
                            <h6 class="text-muted mb-1">Retour prévu</h6>
                            <div class="{{ overdue ? 'text-danger fw-bold' : '' }}">
                                {{ loan.dueDate|date('d/m/Y') }}
                                {% if overdue %}
                                    <i class="bi bi-exclamation-triangle-fill ms-1"></i>
                                {% endif %}
                            </div>
                        </div>

                        {% if loan.returnedAt %}
                            <div class="col-md-4">
                                <h6 class="text-muted mb-1">Retourné le</h6>
                                <div class="text-success">{{ loan.returnedAt|date('d/m/Y à H:i') }}</div>
                            </div>
                        {% endif %}

                        {% if loan.notes %}
                            <div class="col-12">
                                <h6 class="text-muted mb-1">Notes</h6>
                                <div>{{ loan.notes }}</div>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card">
                <div class="card-body d-grid gap-2">
                    {% if loan.status == 'borrowed' %}
                        <form action="{{ path('app_loan_return', {id: loan.id}) }}" method="post"
                              onsubmit="return confirm('Confirmer le retour de ce livre ?')">
                            <input type="hidden" name="_token" value="{{ csrf_token('return_loan_' ~ loan.id) }}">
                            <button type="submit" class="btn btn-success w-100">
                                <i class="bi bi-check-circle me-1"></i>Enregistrer le retour
                            </button>
                        </form>
                    {% endif %}
                    <a href="{{ path('app_loan_index') }}" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-1"></i>Retour à la liste
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
