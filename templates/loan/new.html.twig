{% extends 'base.html.twig' %}

{% block title %}Nouvel emprunt{% endblock %}

{% block body %}
<div class="container">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('app_loan_index') }}">Emprunts</a></li>
            <li class="breadcrumb-item active">Nouvel emprunt</li>
        </ol>
    </nav>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0"><i class="bi bi-plus-circle me-2"></i>Créer un emprunt</h5>
                </div>
                <div class="card-body">
                    {{ form_start(form, {attr: {novalidate: 'novalidate'}}) }}
                        <div class="row g-3">
                            <div class="col-12">{{ form_row(form.book) }}</div>
                            <div class="col-12">{{ form_row(form.member) }}</div>
                            <div class="col-md-6">{{ form_row(form.dueDate) }}</div>
                            <div class="col-12">{{ form_row(form.notes) }}</div>
                        </div>
                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-success">
                                <i class="bi bi-check-lg me-1"></i>Créer l'emprunt
                            </button>
                            <a href="{{ path('app_loan_index') }}" class="btn btn-outline-secondary">Annuler</a>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
