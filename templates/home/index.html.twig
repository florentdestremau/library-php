{% extends 'base.html.twig' %}

{% block title %}Tableau de bord{% endblock %}

{% block body %}
<div class="container">
    <div class="d-flex align-items-center mb-4">
        <h1 class="h3 mb-0"><i class="bi bi-speedometer2 me-2 text-primary"></i>Tableau de bord</h1>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-sm-6 col-xl-3">
            <div class="card h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-primary bg-opacity-10 p-3">
                        <i class="bi bi-journal-text fs-3 text-primary"></i>
                    </div>
                    <div>
                        <div class="fs-2 fw-bold">{{ stats.books }}</div>
                        <div class="text-muted small">Livres au catalogue</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-sm-6 col-xl-3">
            <div class="card h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-success bg-opacity-10 p-3">
                        <i class="bi bi-check-circle fs-3 text-success"></i>
                    </div>
                    <div>
                        <div class="fs-2 fw-bold">{{ stats.available }}</div>
                        <div class="text-muted small">Exemplaires disponibles</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-sm-6 col-xl-3">
            <div class="card h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-info bg-opacity-10 p-3">
                        <i class="bi bi-people fs-3 text-info"></i>
                    </div>
                    <div>
                        <div class="fs-2 fw-bold">{{ stats.members }}</div>
                        <div class="text-muted small">Adhérents actifs</div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-sm-6 col-xl-3">
            <div class="card h-100">
                <div class="card-body d-flex align-items-center gap-3">
                    <div class="rounded-circle bg-warning bg-opacity-10 p-3">
                        <i class="bi bi-arrow-left-right fs-3 text-warning"></i>
                    </div>
                    <div>
                        <div class="fs-2 fw-bold">
                            {{ stats.active_loans }}
                            {% if stats.overdue > 0 %}
                                <span class="badge bg-danger ms-1 badge-overdue" style="font-size:.6rem">{{ stats.overdue }} en retard</span>
                            {% endif %}
                        </div>
                        <div class="text-muted small">Emprunts en cours</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body text-center py-5">
                    <i class="bi bi-search fs-1 text-primary mb-3 d-block"></i>
                    <h5>Rechercher un livre</h5>
                    <p class="text-muted small">Parcourez le catalogue par titre, auteur ou genre</p>
                    <a href="{{ path('app_book_index') }}" class="btn btn-primary">
                        <i class="bi bi-journal-text me-1"></i>Accéder au catalogue
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body text-center py-5">
                    <i class="bi bi-person-plus fs-1 text-info mb-3 d-block"></i>
                    <h5>Gérer les adhérents</h5>
                    <p class="text-muted small">Créer, modifier ou consulter les fiches adhérents</p>
                    <a href="{{ path('app_member_index') }}" class="btn btn-info text-white">
                        <i class="bi bi-people me-1"></i>Voir les adhérents
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body text-center py-5">
                    <i class="bi bi-plus-circle fs-1 text-success mb-3 d-block"></i>
                    <h5>Nouvel emprunt</h5>
                    <p class="text-muted small">Enregistrer le prêt d'un livre à un adhérent</p>
                    <a href="{{ path('app_loan_new') }}" class="btn btn-success">
                        <i class="bi bi-arrow-left-right me-1"></i>Créer un emprunt
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
