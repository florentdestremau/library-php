<div {{ attributes }}>
    {# Filtres #}
    <div class="card mb-4">
        <div class="card-body">
            <div class="row g-3">
                <div class="col-md-5">
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-search"></i></span>
                        <input type="text"
                               class="form-control"
                               placeholder="Titre, auteur, ISBN..."
                               data-model="debounce(300)|query"
                               value="{{ query }}">
                    </div>
                </div>
                <div class="col-md-3">
                    <select class="form-select" data-model="genre">
                        <option value="">Tous les genres</option>
                        {% for g in this.genres %}
                            <option value="{{ g }}" {% if genre == g %}selected{% endif %}>{{ g }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-md-3">
                    <select class="form-select" data-model="availability">
                        <option value="">Toute disponibilité</option>
                        <option value="available" {% if availability == 'available' %}selected{% endif %}>Disponible</option>
                        <option value="unavailable" {% if availability == 'unavailable' %}selected{% endif %}>Indisponible</option>
                    </select>
                </div>
                <div class="col-md-1">
                    <a href="{{ path('app_book_index') }}" class="btn btn-outline-secondary w-100" title="Réinitialiser">
                        <i class="bi bi-x-lg"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>

    {# Results #}
    <div data-loading="addClass(opacity-50)">
        {% set books = this.books %}
        <div class="d-flex justify-content-between align-items-center mb-3">
            <span class="text-muted small">{{ books.totalItemCount }} livre(s) trouvé(s)</span>
        </div>

        {% if books|length == 0 %}
            <div class="text-center py-5 text-muted">
                <i class="bi bi-search fs-1 d-block mb-3"></i>
                Aucun livre ne correspond à votre recherche.
            </div>
        {% else %}
            <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-3 mb-4">
                {% for book in books %}
                    <div class="col">
                        <div class="card h-100">
                            <div class="card-body">
                                <h6 class="card-title mb-1">
                                    <a href="{{ path('app_book_show', {id: book.id}) }}" class="text-decoration-none text-dark stretched-link">
                                        {{ book.title }}
                                    </a>
                                </h6>
                                <p class="text-muted small mb-2">{{ book.author }}</p>
                                <div class="d-flex gap-2 flex-wrap">
                                    <span class="badge bg-secondary">{{ book.genre }}</span>
                                    <span class="badge bg-light text-dark">{{ book.publicationYear }}</span>
                                    <span class="badge {{ book.available ? 'bg-success' : 'bg-danger' }}">
                                        {{ book.availableCopies }}/{{ book.totalCopies }} dispo
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>

            {# Pagination #}
            {% if books.pageCount > 1 %}
                <nav>
                    <ul class="pagination justify-content-center">
                        {% if books.currentPageNumber > 1 %}
                            <li class="page-item">
                                <button class="page-link" data-model="page" data-value="{{ books.currentPageNumber - 1 }}">
                                    <i class="bi bi-chevron-left"></i>
                                </button>
                            </li>
                        {% endif %}

                        {% for p in range(max(1, books.currentPageNumber - 2), min(books.pageCount, books.currentPageNumber + 2)) %}
                            <li class="page-item {{ p == books.currentPageNumber ? 'active' : '' }}">
                                <button class="page-link" data-model="page" data-value="{{ p }}">{{ p }}</button>
                            </li>
                        {% endfor %}

                        {% if books.currentPageNumber < books.pageCount %}
                            <li class="page-item">
                                <button class="page-link" data-model="page" data-value="{{ books.currentPageNumber + 1 }}">
                                    <i class="bi bi-chevron-right"></i>
                                </button>
                            </li>
                        {% endif %}
                    </ul>
                </nav>
            {% endif %}
        {% endif %}
    </div>
</div>
