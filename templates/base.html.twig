<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}Bibliothèque{% endblock %} | LibraryPHP</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>📚</text></svg>">
        {% block stylesheets %}{% endblock %}
        <style>
            body { background-color: #f8f9fa; }
            .navbar-brand { font-weight: 700; font-size: 1.4rem; }
            .sidebar { min-height: calc(100vh - 56px); }
            .nav-link.active { background: rgba(255,255,255,0.15); border-radius: 8px; }
            .card { border: none; box-shadow: 0 1px 3px rgba(0,0,0,.08); }
            .badge-overdue { animation: pulse 2s infinite; }
            @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.6} }
            [data-loading] { transition: opacity .2s; }
            .live-search-spinner { display: none; }
            [data-loading-class] { opacity: 0.6; }
        </style>
        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
        {% endblock %}

        {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
        {% if frankenphpHotReload %}
        <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
        <script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
        <script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
        {% endif %}
    </head>
    <body>
        <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
            <div class="container-fluid">
                <a class="navbar-brand" href="{{ path('app_home') }}">
                    <i class="bi bi-book-fill me-2"></i>LibraryPHP
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link {% if app.request.attributes.get('_route') starts with 'app_book' %}active{% endif %}"
                               href="{{ path('app_book_index') }}">
                                <i class="bi bi-journal-text me-1"></i>Livres
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link {% if app.request.attributes.get('_route') starts with 'app_member' %}active{% endif %}"
                               href="{{ path('app_member_index') }}">
                                <i class="bi bi-people me-1"></i>Adhérents
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link {% if app.request.attributes.get('_route') starts with 'app_loan' %}active{% endif %}"
                               href="{{ path('app_loan_index') }}">
                                <i class="bi bi-arrow-left-right me-1"></i>Emprunts
                            </a>
                        </li>
                    </ul>
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link" href="{{ path('app_loan_new') }}">
                                <i class="bi bi-plus-circle me-1"></i>Nouvel emprunt
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>

        <main class="container-fluid py-4">
            {% for type, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ type == 'error' ? 'danger' : type }} alert-dismissible fade show mx-3 mb-3" role="alert">
                        {{ message }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                {% endfor %}
            {% endfor %}

            {% block body %}{% endblock %}
        </main>

    </body>
</html>
