{% extends 'base.html.twig' %}

{% block title %}{{ member.fullName }}{% endblock %}

{% block body %}
<div class="container">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('app_member_index') }}">Adhérents</a></li>
            <li class="breadcrumb-item active">{{ member.fullName }}</li>
        </ol>
    </nav>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card mb-4">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div>
                            <h1 class="h3 mb-1">{{ member.fullName }}</h1>
                            <p class="text-muted mb-0">{{ member.email }}</p>
                        </div>
                        {% set statusMap = {active: 'success', suspended: 'warning', expired: 'secondary'} %}
                        {% set statusLabel = {active: 'Actif', suspended: 'Suspendu', expired: 'Expiré'} %}
                        <span class="badge fs-6 bg-{{ statusMap[member.status] ?? 'secondary' }}">
                            {{ statusLabel[member.status] ?? member.status }}
                        </span>
                    </div>

                    <div class="row g-3">
                        <div class="col-sm-6">
                            <div class="text-muted small">Téléphone</div>
                            <div>{{ member.phone ?? '—' }}</div>
                        </div>
                        <div class="col-sm-6">
                            <div class="text-muted small">Date de naissance</div>
                            <div>{{ member.birthDate|date('d/m/Y') }}</div>
                        </div>
                        <div class="col-sm-6">
                            <div class="text-muted small">Membre depuis</div>
                            <div>{{ member.membershipDate|date('d/m/Y') }}</div>
                        </div>
                        <div class="col-sm-6">
                            <div class="text-muted small">Expiration</div>
                            <div>{{ member.membershipExpiry ? member.membershipExpiry|date('d/m/Y') : '—' }}</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h5 class="mb-0"><i class="bi bi-book me-2"></i>Emprunts en cours</h5>
                    <span class="badge bg-primary">{{ active_loans|length }}</span>
                </div>
                {% if active_loans|length > 0 %}
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Livre</th>
                                        <th>Emprunté le</th>
                                        <th>Retour prévu</th>
                                        <th>Statut</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for loan in active_loans %}
                                        {% set overdue = loan.dueDate < date() %}
                                        <tr class="{{ overdue ? 'table-warning' : '' }}">
                                            <td>
                                                <a href="{{ path('app_book_show', {id: loan.book.id}) }}">
                                                    {{ loan.book.title|u.truncate(35, '…') }}
                                                </a>
                                            </td>
                                            <td>{{ loan.borrowedAt|date('d/m/Y') }}</td>
                                            <td class="{{ overdue ? 'text-danger fw-bold' : '' }}">
                                                {{ loan.dueDate|date('d/m/Y') }}
                                            </td>
                                            <td>
                                                <span class="badge {{ overdue ? 'bg-danger' : 'bg-warning text-dark' }}">
                                                    {{ overdue ? 'En retard' : 'En cours' }}
                                                </span>
                                            </td>
                                            <td>
                                                <a href="{{ path('app_loan_show', {id: loan.id}) }}" class="btn btn-sm btn-outline-primary">
                                                    <i class="bi bi-eye"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                {% else %}
                    <div class="card-body text-center text-muted py-4">
                        Aucun emprunt en cours.
                    </div>
                {% endif %}
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card">
                <div class="card-body d-grid gap-2">
                    <a href="{{ path('app_loan_new') }}" class="btn btn-success">
                        <i class="bi bi-plus-circle me-1"></i>Nouvel emprunt
                    </a>
                    <a href="{{ path('app_member_edit', {id: member.id}) }}" class="btn btn-outline-primary">
                        <i class="bi bi-pencil me-1"></i>Modifier
                    </a>
                    <form action="{{ path('app_member_delete', {id: member.id}) }}" method="post"
                          onsubmit="return confirm('Supprimer cet adhérent ?')">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete_member_' ~ member.id) }}">
                        <button type="submit" class="btn btn-outline-danger w-100">
                            <i class="bi bi-trash me-1"></i>Supprimer
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
