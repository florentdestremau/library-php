{% extends 'base.html.twig' %}

{% block title %}{{ book.title }}{% endblock %}

{% block body %}
<div class="container">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('app_book_index') }}">Livres</a></li>
            <li class="breadcrumb-item active">{{ book.title|u.truncate(40, '…') }}</li>
        </ol>
    </nav>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card mb-4">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div>
                            <h1 class="h3 mb-1">{{ book.title }}</h1>
                            <p class="text-muted fs-5 mb-0">{{ book.author }}</p>
                        </div>
                        <span class="badge fs-6 {{ book.available ? 'bg-success' : 'bg-danger' }}">
                            {{ book.availableCopies }}/{{ book.totalCopies }} disponible(s)
                        </span>
                    </div>

                    <div class="d-flex gap-2 flex-wrap mb-3">
                        <span class="badge bg-primary">{{ book.genre }}</span>
                        <span class="badge bg-secondary">{{ book.publicationYear }}</span>
                        {% if book.isbn %}
                            <span class="badge bg-light text-dark">ISBN: {{ book.isbn }}</span>
                        {% endif %}
                    </div>

                    {% if book.description %}
                        <p class="text-muted">{{ book.description }}</p>
                    {% endif %}
                </div>
            </div>

            {% if active_loans|length > 0 %}
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0"><i class="bi bi-person-check me-2"></i>Emprunts en cours</h5>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Adhérent</th>
                                        <th>Emprunté le</th>
                                        <th>Retour prévu</th>
                                        <th>Statut</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for loan in active_loans %}
                                        {% set overdue = loan.dueDate < date() %}
                                        <tr class="{{ overdue ? 'table-warning' : '' }}">
                                            <td>
                                                <a href="{{ path('app_member_show', {id: loan.member.id}) }}">
                                                    {{ loan.member.fullName }}
                                                </a>
                                            </td>
                                            <td>{{ loan.borrowedAt|date('d/m/Y') }}</td>
                                            <td class="{{ overdue ? 'text-danger fw-bold' : '' }}">
                                                {{ loan.dueDate|date('d/m/Y') }}
                                            </td>
                                            <td>
                                                <span class="badge {{ overdue ? 'bg-danger' : 'bg-warning text-dark' }}">
                                                    {{ overdue ? 'En retard' : 'En cours' }}
                                                </span>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            {% endif %}
        </div>

        <div class="col-lg-4">
            <div class="card mb-3">
                <div class="card-body d-grid gap-2">
                    {% if book.available %}
                        <a href="{{ path('app_loan_new', {book: book.id}) }}" class="btn btn-success">
                            <i class="bi bi-arrow-left-right me-1"></i>Créer un emprunt
                        </a>
                    {% else %}
                        <button class="btn btn-secondary" disabled>
                            <i class="bi bi-x-circle me-1"></i>Aucun exemplaire disponible
                        </button>
                    {% endif %}
                    <a href="{{ path('app_book_edit', {id: book.id}) }}" class="btn btn-outline-primary">
                        <i class="bi bi-pencil me-1"></i>Modifier
                    </a>
                    <form action="{{ path('app_book_delete', {id: book.id}) }}" method="post"
                          onsubmit="return confirm('Supprimer ce livre ?')">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete_book_' ~ book.id) }}">
                        <button type="submit" class="btn btn-outline-danger w-100">
                            <i class="bi bi-trash me-1"></i>Supprimer
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
