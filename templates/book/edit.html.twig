{% extends 'base.html.twig' %}

{% block title %}Modifier — {{ book.title }}{% endblock %}

{% block body %}
<div class="container">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a href="{{ path('app_book_index') }}">Livres</a></li>
            <li class="breadcrumb-item"><a href="{{ path('app_book_show', {id: book.id}) }}">{{ book.title|u.truncate(30, '…') }}</a></li>
            <li class="breadcrumb-item active">Modifier</li>
        </ol>
    </nav>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0"><i class="bi bi-pencil me-2"></i>Modifier le livre</h5>
                </div>
                <div class="card-body">
                    {{ form_start(form, {attr: {novalidate: 'novalidate'}}) }}
                        <div class="row g-3">
                            <div class="col-md-8">{{ form_row(form.title) }}</div>
                            <div class="col-md-4">{{ form_row(form.publicationYear) }}</div>
                            <div class="col-md-8">{{ form_row(form.author) }}</div>
                            <div class="col-md-4">{{ form_row(form.isbn) }}</div>
                            <div class="col-md-6">{{ form_row(form.genre) }}</div>
                            <div class="col-md-6">{{ form_row(form.totalCopies) }}</div>
                            <div class="col-12">{{ form_row(form.description) }}</div>
                        </div>
                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-lg me-1"></i>Enregistrer
                            </button>
                            <a href="{{ path('app_book_show', {id: book.id}) }}" class="btn btn-outline-secondary">Annuler</a>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
